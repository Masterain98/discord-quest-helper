{
  "name": "discord-quest-helper",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.28.0",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "pnpm run build:runner && pnpm run build:cdp-launcher && tauri dev -- --bin discord-quest-helper",
    "tauri:build": "pnpm run build:runner && pnpm run build:cdp-launcher && tauri build",
    "build:runner": "node scripts/build-runner.js",
    "build:cdp-launcher": "node scripts/build-cdp-launcher.js",
    "analyze:har": "python scripts/analyze-har-quests.py",
    "test": "vitest run",
    "test:quest-schema": "python scripts/validate-quest-schema-fixture.py tests/fixtures/quests_2026_06_16.schema.json"
  },
  "dependencies": {
    "@tauri-apps/plugin-dialog": "^2",
    "@tauri-apps/plugin-fs": "^2.4.5",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "@vueuse/core": "^14.2.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-vue-next": "^0.577.0",
    "pinia": "^3.0.4",
    "radix-vue": "^1.9.17",
    "tailwind-merge": "^3.4.1",
    "tailwindcss-animate": "^1.0.7",
    "vue": "^3.5.39",
    "vue-i18n": "^11.3.2",
    "vue-router": "^5.0.7"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.4",
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/cli": "^2.11.4",
    "@vitejs/plugin-vue": "^6.0.7",
    "postcss": "^8.5.16",
    "tailwindcss": "^4.2.4",
    "typescript": "^5.3.0",
    "vite": "^7.3.6",
    "vitest": "^4.0.15",
    "vue-tsc": "^3.2.9"
  }
}
